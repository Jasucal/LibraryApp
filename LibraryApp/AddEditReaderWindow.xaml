<Window x:Class="LibraryApp.AddEditReaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LibraryApp.Helpers"
        local:ClickClearFocusBehavior.IsEnabled="True"
        Title="Управление читателями" Height="380" Width="450" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Content="ФИО:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtFullName" Grid.Row="0" Grid.Column="1" Margin="0,5,0,5" 
                 PreviewTextInput="TxtFullName_PreviewTextInput" DataObject.Pasting="TxtFullName_Pasting"/>

        <Label Content="Дата рождения:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
        <DatePicker x:Name="dpDateOfBirth" Grid.Row="1" Grid.Column="1" Margin="0,5,0,5"/>

        <Label Content="Телефон:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
        <Grid Grid.Row="2" Grid.Column="1" Margin="0,5,0,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBox x:Name="txtPhoneNumber" Grid.Row="0" Margin="0,0,0,3"/>

            <TextBlock Grid.Row="1" Text="Формат: +7-XXX-XXX-XX-XX" FontSize="11" Foreground="Gray"
                       Margin="2,0,0,0"/>
        </Grid>

        <Label Content="Email:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtEmail" Grid.Row="3" Grid.Column="1" Margin="0,5,0,5"/>

        <Label Content="Пароль:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="4" Grid.Column="1" Margin="0,5,0,5" Height="30" FontSize="14"
             VerticalContentAlignment="Center"/>

        <Label Content="Роль:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBlock x:Name="txtRole" Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" Margin="0,5,0,5"
                   FontWeight="Bold" FontSize="13" 
                   HorizontalAlignment="Left"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center"
                    VerticalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Сохранить" Width="120" Height="35" Margin="0,0,10,0" Click="BtnSave_Click"/>
            <Button Content="Отмена" Width="120" Height="35" Margin="0,0,10,0" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>