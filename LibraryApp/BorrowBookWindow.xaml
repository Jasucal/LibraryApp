<Window x:Class="LibraryApp.BorrowBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выдать книгу" Height="325" Width="350" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Content="Читатель" Grid.Row="0" Margin="0,0,0,5" FontWeight="Bold"/>
        <ComboBox x:Name="cbReaders" Grid.Row="1" 
                  IsEditable="True"
                  IsTextSearchEnabled="False"
                  DisplayMemberPath="FullName" 
                  SelectedValuePath="Id"
                  KeyUp="CbReaders_KeyUp"
                  Margin="0,0,0,15"/>

        <Label Content="Книга" Grid.Row="2" Margin="0,0,0,5" FontWeight="Bold"/>
        <ComboBox x:Name="cbBooks" Grid.Row="3"
                  IsEditable="True"
                  IsTextSearchEnabled="False"
                  DisplayMemberPath="DisplayTitle" 
                  SelectedValuePath="Id"
                  KeyUp="CbBooks_KeyUp"
                  Margin="0,0,0,15"/>

        <Label Content="Дата возврата" Grid.Row="4" Margin="0,0,0,5" FontWeight="Bold"/>
        <DatePicker x:Name="dpReturnDate" Grid.Row="5" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <Button Content="Сохранить" Width="100" Height="30" Margin="5" Click="BtnSave_Click"/>
            <Button Content="Отмена" Width="100" Height="30" Margin="5" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>