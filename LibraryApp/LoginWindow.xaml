<Window x:Class="LibraryApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LibraryApp.Helpers"
        local:ClickClearFocusBehavior.IsEnabled="True"
        Title="Авторизация" Width="350" Height="314" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Top" Margin="0,0,0,10">
            <Label Content="Email:"/>
            <TextBox x:Name="tbEmail" Width="250" Height="25" Margin="0,2,0,10"
                     VerticalContentAlignment="Center" Padding="2,0,2,0"/>

            <Label Content="Пароль:"/>
            <PasswordBox x:Name="tbPassword" Width="250" Height="25" Margin="0,2,0,0"
                         VerticalContentAlignment="Center" Padding="2,0,2,0"/>
        </StackPanel>

        <Button Grid.Row="1" Content="Войти" Width="250" Height="30"
                HorizontalAlignment="Center" Margin="0,10,0,0"
                Click="BtnLogin_Click"/>

        <StackPanel Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,10,0,10">
            <TextBlock>
                <Hyperlink Click="HyperlinkRegister_Click">Регистрация</Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>