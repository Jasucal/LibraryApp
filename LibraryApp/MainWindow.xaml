<Window x:Class="LibraryApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LibraryApp.Helpers"
        local:ClickClearFocusBehavior.IsEnabled="True"
        Title="Библиотека" Height="800" Width="1100" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <EventSetter Event="PreviewMouseDown" Handler="DataGrid_PreviewMouseDown"/>
        </Style>
    </Window.Resources>
    

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtSearch" Grid.Column="0" VerticalAlignment="Center" MinWidth="100" Padding="8,2"
                     FontSize="14" Margin="0,0,5,0" TextChanged="TxtSearch_TextChanged"
                     local:TextBoxPlaceholder.Text="🕵️ Поиск"/>

            <Button Content="👤 Профиль" Width="90" Grid.Column="1" Margin="5,0,10,0"
                    VerticalAlignment="Center" Click="BtnProfile_Click"/>
        </Grid>

        <TabControl x:Name="tabMain" Grid.Row="1" SelectionChanged="TabMain_SelectionChanged">

            <TabItem Header="Книги">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgBooks" AutoGenerateColumns="False" IsReadOnly="True" 
                              Margin="0,0,0,5" Grid.Row="0">

                        <DataGrid.Resources>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAdult}" Value="True">
                                        <Setter Property="Background" Value="#FFEDDE3B"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="Автор" Binding="{Binding AuthorName}" Width="150"/>
                            <DataGridTextColumn Header="Издательство" Binding="{Binding Publisher}" Width="150"/>
                            <DataGridTextColumn Header="Жанр" Binding="{Binding Genre}" Width="120"/>
                            <DataGridTextColumn Header="Год" Binding="{Binding Year}" Width="80"/>
                            <DataGridCheckBoxColumn Header="Доступна" Binding="{Binding IsAvailable}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DataGrid x:Name="dgBorrowed" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,5,0,5" Grid.Row="1"
                            MouseDoubleClick="dgBorrowed_MouseDoubleClick">

                        <DataGrid.Resources>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOverdue}" Value="1">
                                        <Setter Property="Background" Value="LightCoral"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Книга" Binding="{Binding BookTitle}" Width="*"/>
                            <DataGridTextColumn Header="Читатель" Binding="{Binding ReaderName}" Width="240"/>
                            <DataGridTextColumn Header="Дата выдачи" Binding="{Binding BorrowDate}" Width="170"/>
                            <DataGridTextColumn Header="Плановая дата возврата" Binding="{Binding ExpectedReturnDate}" Width="170"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="📄 Создать отчёт"
                                Width="125" Margin="5" Grid.Column="0" Click="BtnExportBooks_Click"/>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="📖 Выдать книгу" Width="120" Margin="5" Click="BtnBorrowBook_Click"/>
                            <Button Content="📖 Возврат книги" Width="120" Margin="5" Click="BtnReturnBook_Click"/>
                            <Button Content="📘 Добавить" Width="100" Margin="5" Click="BtnAddBook_Click"/>
                            <Button Content="📘 Редактировать" Width="120" Margin="5" Click="BtnEditBook_Click"/>
                            <Button Content="📘 Удалить" Width="100" Margin="5" Click="BtnDeleteBook_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Авторы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgAuthors" AutoGenerateColumns="False" IsReadOnly="True"
                              Margin="0,0,0,5" Grid.Row="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding Name}" Width="150"/>
                            <DataGridTextColumn Header="Дата рождения"
                                                Binding="{Binding DateOfBirth, StringFormat=\{0:dd.MM.yyyy\}}"
                                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="📄 Создать отчёт"
                                Width="125" Margin="5" Grid.Column="0" Click="BtnExportAuthors_Click"/>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="🤵 Добавить" Width="100" Margin="5" Click="BtnAddAuthor_Click"/>
                            <Button Content="🤵 Редактировать" Width="120" Margin="5" Click="BtnEditAuthor_Click"/>
                            <Button Content="🤵 Удалить" Width="100" Margin="5" Click="BtnDeleteAuthor_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Пользователи">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgReaders" AutoGenerateColumns="False" IsReadOnly="True"
                              Margin="0,0,0,5" Grid.Row="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Дата рождения"
                                                Binding="{Binding DateOfBirth, StringFormat=\{0:dd.MM.yyyy\}}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding PhoneNumber}" Width="120"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="140"/>
                            <DataGridTemplateColumn Header="Пароль" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="••••••••" 
                                                   VerticalAlignment="Center"
                                                   Margin="5,0,0,0"
                                                   Foreground="Gray"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Роль" Binding="{Binding RoleName}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="📄 Создать отчёт"
                                Width="125" Margin="5" Grid.Column="0" Click="BtnExportReaders_Click"/>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="🙍‍♂️ Добавить" Width="100" Margin="5" Click="BtnAddReader_Click"/>
                            <Button Content="🙍‍♂️ Редактировать" Width="120" Margin="5" Click="BtnEditReader_Click"/>
                            <Button Content="🙍‍♂️ Удалить" Width="100" Margin="5" Click="BtnDeleteReader_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="История">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <DataGrid x:Name="dgHistory" AutoGenerateColumns="False" IsReadOnly="True"
                              Margin="0,0,0,5" Grid.Row="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Книга" Binding="{Binding BookTitle}" Width="200"/>
                            <DataGridTextColumn Header="Читатель" Binding="{Binding ReaderName}" Width="*"/>
                            <DataGridTextColumn Header="Дата выдачи"
                                                Binding="{Binding BorrowDate, StringFormat=\{0:dd.MM.yyyy\}}"
                                                Width="90"/>
                            <DataGridTextColumn Header="ПДВ"
                                                Binding="{Binding ExpectedReturnDate, StringFormat=\{0:dd.MM.yyyy\}}"
                                                Width="90"/>
                            <DataGridTextColumn Header="ФДВ"
                                                Binding="{Binding ReturnDate, StringFormat=\{0:dd.MM.yyyy\}}"
                                                Width="90"/>
                            <DataGridTextColumn Header="Выдал" Binding="{Binding IssuedBy}" Width="185"/>
                            <DataGridTextColumn Header="Принял" Binding="{Binding ReturnedBy}" Width="185"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="📄 Создать отчёт"
                                Width="125" Margin="5" Grid.Column="0" Click="BtnExportHistory_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Статистика">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <GroupBox Grid.Row="0" Header="Самые популярные книги" Margin="0,0,0,5">
                        <DataGrid x:Name="dgPopularBooks" AutoGenerateColumns="False" IsReadOnly="True"
                                  Margin="5">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Rank}" Value="1">
                                            <Setter Property="Background" Value="#FFD700"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Rank}" Value="2">
                                            <Setter Property="Background" Value="#C0C0C0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Rank}" Value="3">
                                            <Setter Property="Background" Value="#CD7F32"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Место" Binding="{Binding Rank}" Width="60"/>
                                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                                <DataGridTextColumn Header="Автор" Binding="{Binding AuthorName}" Width="150"/>
                                <DataGridTextColumn Header="Выдач" Binding="{Binding BorrowCount}" Width="80"/>
                                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <GroupBox Grid.Row="1" Header="Самые популярные авторы" Margin="0,5,0,5">
                        <DataGrid x:Name="dgPopularAuthors" AutoGenerateColumns="False" IsReadOnly="True"
                                  Margin="5">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Rank}" Value="1">
                                            <Setter Property="Background" Value="#FFD700"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Rank}" Value="2">
                                            <Setter Property="Background" Value="#C0C0C0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Rank}" Value="3">
                                            <Setter Property="Background" Value="#CD7F32"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Место" Binding="{Binding Rank}" Width="60"/>
                                <DataGridTextColumn Header="ФИО" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Книг в выдаче" Binding="{Binding TotalBorrows}" Width="120"/>
                                <DataGridTextColumn Header="Уникальных книг" Binding="{Binding UniqueBooks}" Width="120"/>
                                <DataGridTextColumn Header="Дата рождения" 
                                                    Binding="{Binding DateOfBirth, StringFormat=\{0:dd.MM.yyyy\}}" 
                                                    Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                                Margin="0,10,0,0">
                        <Button Content="📄 Экспорт" Width="100" Margin="5" Click="BtnExportStats_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>