<Window x:Class="LibraryApp.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Профиль пользователя" Height="380" Width="580" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" Background="#FAFAFA">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="tbFullName" Grid.Row="0" FontSize="24" FontWeight="Bold" Foreground="#222" Margin="0,0,0,5"/>
        <TextBlock x:Name="tbRole" Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Center" 
                   FontSize="14" Foreground="#666" FontStyle="Italic"/>

        <Separator Grid.Row="1" Margin="0,10" Foreground="#DDD"/>

        <!-- Основная информация -->
        <Grid Grid.Row="2" Margin="0,10,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="🎂 Дата рождения:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBlock x:Name="tbDob" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0"/>

            <TextBlock Text="📞 Телефон:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBlock x:Name="tbPhone" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0"/>

            <TextBlock Text="📧 Почта:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBlock x:Name="tbEmail" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Margin="8,0,0,0"/>
        </Grid>

        <!-- Статистика библиотекаря -->
        <GroupBox x:Name="gbLibrarian" Grid.Row="3" Header="👨‍ Статистика библиотекаря" 
                  Visibility="Collapsed" BorderBrush="#0078D7" Foreground="#0078D7">
            <Grid Margin="15,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Выдано книг" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbIssued" FontSize="28" FontWeight="Bold" Foreground="#0078D7" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Возвращено книг" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbReturned" FontSize="28" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Статистика читателя -->
        <GroupBox x:Name="gbReader" Grid.Row="3" Header="👤 Статистика читателя" 
                  Visibility="Collapsed" BorderBrush="#FF9800" Foreground="#E65100">
            <Grid Margin="15,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Прочитано книг" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbRead" FontSize="28" FontWeight="Bold" Foreground="#FF9800" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Любимая книга" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbFavorite" FontSize="16" FontWeight="SemiBold" Foreground="#333" 
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
            <!-- 🔹 Кнопка выхода в стиле приложения -->
            <Button Content="Выйти" 
                    Width="80" Height="30" Margin="0,0,10,0" 
                    Click="BtnLogout_Click"/>

            <!-- Кнопка закрытия окна профиля -->
            <Button Content="Закрыть" 
                    Width="80" Height="30" Margin="10,0,0,0" 
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>