<Window x:Class="LibraryApp.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="480" Width="420" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Orientation="Vertical">

            <TextBlock Text="ФИО:" Margin="0,0,0,3"/>
            <TextBox x:Name="txtFullName"
                     Height="28"
                     Margin="0,0,0,10"
                     Padding="4,3"
                     PreviewTextInput="TxtFullName_PreviewTextInput"
                     DataObject.Pasting="TxtFullName_Pasting"/>

            <TextBlock Text="Дата рождения:" Margin="0,0,0,3"/>
            <DatePicker x:Name="dpDateOfBirth"
                        Height="28"
                        Margin="0,0,0,10"
                        Padding="4,3"/>

            <TextBlock Text="Телефон:" Margin="0,0,0,3"/>
            <TextBox x:Name="txtPhoneNumber"
                     Height="28"
                     Margin="0,0,0,3"
                     Padding="4,3"/>

            <TextBlock Text="Формат: +7-XXX-XXX-XX-XX"
                       FontSize="11"
                       Foreground="Gray"
                       Margin="2,0,0,10"/>

            <TextBlock Text="Email:" Margin="0,0,0,3"/>
            <TextBox x:Name="txtEmail"
                     Height="28"
                     Margin="0,0,0,10"
                     Padding="4,3"/>

            <TextBlock Text="Пароль:" Margin="0,0,0,3"/>
            <PasswordBox x:Name="txtPassword"
                         Height="28"
                         Margin="0,0,0,20"
                         VerticalContentAlignment="Center"
                         Padding="4,1"/>

            <Button Content="Зарегистрироваться"
                    Width="250"
                    Height="30"
                    HorizontalAlignment="Center"
                    Click="BtnRegister_Click"/>

            <Button Content="Отмена"
                    Width="250"
                    Height="30"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </ScrollViewer>
</Window>