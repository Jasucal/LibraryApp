<Window x:Class="LibraryApp.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание отчётов" Height="245" Width="240" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="Отчёт по книгам" Width="200" Height="35" Margin="0,10,0,5" HorizontalAlignment="Center" Click="BtnBooksReport_Click"/>
        <Button Grid.Row="1" Content="Отчёт по авторам" Width="200" Height="35" Margin="0,10,0,5" HorizontalAlignment="Center" Click="BtnAuthorsReport_Click"/>
        <Button Grid.Row="2" Content="Отчёт по читателям" Width="200" Height="35" Margin="0,10,0,5" HorizontalAlignment="Center" Click="BtnReadersReport_Click"/>
        <Button Grid.Row="3" Content="Отчёт по истории" Width="200" Height="35" Margin="0,10,0,5" HorizontalAlignment="Center" Click="BtnHistoryReport_Click"/>
    </Grid>
</Window>
