<Window x:Class="LibraryApp.ReturnBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Возврат книги" Height="160" Width="400" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel x:Name="spSearch" Grid.Row="0" Orientation="Vertical" Margin="0,0,0,0">
            <Label Content="Поиск:" Margin="2,0,0,2"/>
            <ComboBox x:Name="cbBorrows" 
                      IsEditable="True"
                      IsTextSearchEnabled="False"
                      DisplayMemberPath="DisplayText" 
                      SelectedValuePath="Id" 
                      Margin="5,0,0,5"
                      KeyUp="CbBorrows_KeyUp"/>
        </StackPanel>

        <TextBlock x:Name="tbNoBorrows" Grid.Row="0" Text="Нет записей для возврата" 
                   Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="2" Margin="0,10,0,0">
            <Button x:Name="btnReturn" Content="Вернуть" Width="100" Margin="5" Click="BtnReturn_Click"/>
            <Button Content="Отмена" Width="100" Margin="5" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>