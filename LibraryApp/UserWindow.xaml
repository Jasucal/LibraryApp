<Window x:Class="LibraryApp.UserMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LibraryApp.Helpers"
        local:ClickClearFocusBehavior.IsEnabled="True"
        Title="Библиотека" Height="800" Width="1100" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <EventSetter Event="PreviewMouseDown" Handler="DataGrid_PreviewMouseDown"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtSearch" Grid.Column="0" VerticalAlignment="Center" MinWidth="100" Padding="8,2"
                     FontSize="14" Margin="0,0,5,0" TextChanged="TxtSearch_TextChanged"
                     local:TextBoxPlaceholder.Text="🕵️ Поиск"/>

            <Button Content="👤 Профиль" Width="90" Grid.Column="1" Margin="5,0,10,0"
        VerticalAlignment="Center" Click="BtnProfile_Click"/>
        </Grid>

        <TabControl x:Name="tabMain" Grid.Row="1" SelectionChanged="TabMain_SelectionChanged">
            <TabItem Header="Все книги">
                <DataGrid x:Name="dgBooks" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAdult}" Value="True">
                                    <Setter Property="Background" Value="#FFEDDE3B"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="25"/>
                        <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                        <DataGridTextColumn Header="Автор" Binding="{Binding AuthorName}" Width="180"/>
                        <DataGridTextColumn Header="Издательство" Binding="{Binding Publisher}" Width="200"/>
                        <DataGridTextColumn Header="Жанр" Binding="{Binding Genre}" Width="150"/>
                        <DataGridTextColumn Header="Год" Binding="{Binding Year}" Width="100"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding IsAvailable}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Мои книги">
                <DataGrid x:Name="dgBorrowed" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOverdue}" Value="1">
                                    <Setter Property="Background" Value="LightCoral"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding BookId}" Width="25"/>
                        <DataGridTextColumn Header="Название" Binding="{Binding BookTitle}" Width="150"/>
                        <DataGridTextColumn Header="Автор" Binding="{Binding AuthorName}" Width="150"/>
                        <DataGridTextColumn Header="Издательство" Binding="{Binding Publisher}" Width="150"/>
                        <DataGridTextColumn Header="Дата выдачи" Binding="{Binding BorrowDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="110"/>
                        <DataGridTextColumn Header="Ожидаемая дата возврата" Binding="{Binding ExpectedReturnDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="180"/>
                        <DataGridTextColumn Header="Фактическая дата возврата" Binding="{Binding ReturnDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>